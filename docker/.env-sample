# Copy this file to .env in the repo root:
#   cp docker/.env-sample .env
#
# The docker-compose.yaml has sensible defaults for ALL variables.
# An empty .env file works fine for local development without OAuth.
# Only uncomment and set values you need to override.

# --- OAuth (optional) ---
# Uncomment and fill in to enable Google OAuth login.
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Add http://localhost:8081/login/callback as an Authorized redirect URI.
#
# ENABLE_OAUTH=true
# OAUTH_PROVIDER=google
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_ISSUER=https://accounts.google.com
# OAUTH_REDIRECT_URL=http://localhost:8081/login/callback
# AFTER_LOGIN_URL=http://localhost
# ALLOWED_REDIRECT_URLS=http://localhost,http://localhost:3001

# --- Service URLs (defaults match docker-compose) ---
# ACTIX_UI_BACKEND_URL=ws://localhost:8080
# API_BASE_URL=http://localhost:8081
# WEBTRANSPORT_HOST=https://127.0.0.1:4433

# --- JWT ---
# JWT_SECRET=dev-jwt-secret-change-me-for-local
