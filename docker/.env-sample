# Copy this file to .env in the repo root:
#   cp docker/.env-sample .env
#
# The docker-compose.yaml has sensible defaults for ALL variables.
# An empty .env file works fine for local development without OAuth.
# Only uncomment and set values you need to override.

# --- OAuth (optional) ---
# Uncomment and fill in to enable OAuth login with PKCE.
#
# The dioxus-ui performs the PKCE authorization flow directly in the browser:
#   1. Reads OAUTH_AUTH_URL and OAUTH_CLIENT_ID from window.__APP_CONFIG.
#   2. Generates code_verifier / code_challenge / state / nonce locally.
#   3. Redirects the user to OAUTH_AUTH_URL with PKCE parameters.
#   4. The provider redirects back to OAUTH_REDIRECT_URL (/auth/callback).
#   5. The UI calls POST /api/v1/oauth/exchange (server keeps client_secret).
#
# Register OAUTH_REDIRECT_URL as an Authorized Redirect URI with your provider.
# Example (Google): https://console.cloud.google.com/apis/credentials
# Example (Okta):   Developer Console → Applications → Redirect URIs
#
# ENABLE_OAUTH=true
# OAUTH_PROVIDER=google
# OAUTH_CLIENT_ID=your-public-client-id
# OAUTH_CLIENT_SECRET=your-client-secret       # stays server-side only
# OAUTH_ISSUER=https://accounts.google.com     # enables OIDC discovery
# OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
# OAUTH_REDIRECT_URL=http://localhost:3001/auth/callback
# AFTER_LOGIN_URL=http://localhost:3001
# ALLOWED_REDIRECT_URLS=http://localhost,http://localhost:3001

# --- Service URLs (defaults match docker-compose) ---
# ACTIX_UI_BACKEND_URL=ws://localhost:8080
# API_BASE_URL=http://localhost:8081
# WEBTRANSPORT_HOST=https://127.0.0.1:4433

# --- JWT ---
# JWT_SECRET=dev-jwt-secret-change-me-for-local
