{
  "name": "videocall-e2e",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "ci:lint": "eslint . && prettier --check . && tsc --noEmit",
    "bot": "tsx bots-app/src/cli.ts",
    "test:unit": "vitest run bots-app/"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "commander": "^14.0.1",
    "eslint": "^10.0.2",
    "jsonwebtoken": "^9.0.2",
    "prettier": "^3.8.1",
    "tsx": "^4.20.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.5"
  }
}
